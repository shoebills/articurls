DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_HOSTNAME=
DATABASE_PORT=

SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

REDIS_URL=

EMAIL_PROVIDER=
# SMTP_* / FROM_EMAIL required when EMAIL_PROVIDER is not resend.
SMTP_HOST=
SMTP_PORT=
RESEND_API_KEY=
FROM_EMAIL=

DODOPAYMENTS_API_KEY=
DODOPAYMENTS_WEBHOOK_KEY=
DODOPAYMENTS_ENVIRONMENT=
DODOPAYMENTS_PRODUCT_ID=

# Origin of this FastAPI service (no trailing slash). Email links for reset-password,
# unsubscribe, and confirm-subscription use this host.
PUBLIC_BASE_URL=http://localhost:8000
UPLOADS_DIR=
STORAGE_BACKEND=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
# Same public R2 URL for Next.js <Image /> allowlist (optional; set in web env / Vercel).
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=
DEFAULT_PROFILE_IMAGE_URL=

# Reader-facing site origin for blog URLs in notification emails (match NEXT_PUBLIC_MARKETING_ORIGIN in prod).
MARKETING_ORIGIN=http://localhost:3000

# Comma-separated browser origins allowed to call the API (Next.js dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Next.js app URL for links in verification email (e.g. https://app.articurls.com)
APP_BASE_URL=http://localhost:3000

# Public API base used by browser and server components.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Marketing/public origin (canonical URLs, nav, branding). Keep in sync with MARKETING_ORIGIN on the API.
NEXT_PUBLIC_MARKETING_ORIGIN=https://articurls.com

# App origin (login/dashboard domain).
NEXT_PUBLIC_APP_ORIGIN=https://app.articurls.com

# Production split example: PUBLIC_BASE_URL=https://api.example.com, MARKETING_ORIGIN and
# NEXT_PUBLIC_MARKETING_ORIGIN=https://example.com, APP_BASE_URL / NEXT_PUBLIC_APP_ORIGIN=https://app.example.com